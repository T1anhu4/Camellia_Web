# ============================================================
# LLM Gateway — Production Environment Configuration
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# All values marked "changeme" or "replace-" MUST be changed.
# ============================================================

# --- Domain Configuration ---
DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com

# Let's Encrypt notification email
ACME_EMAIL=admin@yourdomain.com

# --- Docker Image Version ---
VERSION=latest
DOCKER_REPO=llmgw

# --- Replicas ---
GATEWAY_REPLICAS=2
FRONTEND_REPLICAS=2

# --- Database (PostgreSQL) ---
DB_USER=llmgateway
DB_PASSWORD=generate-a-strong-password-here
DB_NAME=llmgateway

# --- Redis ---
# Leave empty for no password
REDIS_PASSWORD=

# --- Security ---
# Generate JWT secret:    openssl rand -hex 32
# Generate encryption key: openssl rand -hex 16
JWT_SECRET=replace-with-64-char-hex-string
ENCRYPTION_KEY=replace-with-32-char-hex-string

# --- Frontend URLs ---
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# --- Email (SMTP for verification codes) ---
# Leave SMTP_HOST empty to use dev mode (codes printed to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# --- Payment (Stripe) ---
# Leave empty to use stub mode
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Payment (Alipay — future) ---
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# --- Observability ---
# Prometheus metrics endpoint: GET /metrics
# Log level: debug, info, warn, error
LOG_LEVEL=info
